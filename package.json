{
  "name": "opencode-session-metrics",
  "version": "0.1.0",
  "description": "TUI token usage and cost tracking for OpenCode sessions",
  "keywords": [
    "cost",
    "oc-plugin",
    "opencode",
    "tokens",
    "usage"
  ],
  "homepage": "https://github.com/gerardbalaoro/opencode-session-metrics#readme",
  "bugs": {
    "url": "https://github.com/gerardbalaoro/opencode-session-metrics/issues"
  },
  "license": "MIT",
  "author": "gerardbalaoro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gerardbalaoro/opencode-session-metrics.git"
  },
  "files": [
    "src/**/*",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": "./src/plugin.tsx",
    "./tui": "./src/plugin.tsx"
  },
  "scripts": {
