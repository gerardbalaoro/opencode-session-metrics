  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.18.4",
    "@opentui/solid": "^0.4.5",
    "solid-js": "1.9.12"
  },
  "engines": {
    "opencode": ">=1.18.3"
  },
  "oc-plugin": [
    "tui"
  ]
